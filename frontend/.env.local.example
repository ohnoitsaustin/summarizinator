# Copy this file to .env.local and fill in the values.

# GitHub OAuth app — used for connecting GitHub as a data source (not for login).
# Callback URL must include http://localhost:5173/connect/github/callback.
VITE_GITHUB_CLIENT_ID=your_github_client_id

# Cognito — get these from CDK outputs after deploy, or from AWS Console.
# User Pool: Cognito > User Pools > summarizinator-dev
VITE_COGNITO_USER_POOL_ID=us-east-1_XXXXXXXXX
VITE_COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
VITE_COGNITO_DOMAIN=summarizinator-dev.auth.us-east-1.amazoncognito.com
