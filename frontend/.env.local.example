# Copy this file to .env.local and fill in the values.

# The deployed API/CloudFront URL to proxy /api requests to.
# Use the CloudFront domain so auth cookies and CORS headers match production.
# Example: https://dev.summarizinator.com
API_URL=https://your-env.summarizinator.com

# GitHub OAuth app client ID.
# For local dev you need an OAuth app whose callback URL includes
# http://localhost:5173/auth/callback — either add it to your existing
# app or create a separate one at https://github.com/settings/applications/new
VITE_GITHUB_CLIENT_ID=your_github_client_id
