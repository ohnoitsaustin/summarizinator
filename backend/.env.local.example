# Copy this file to .env.local and fill in the values.
# AWS credentials are picked up from your default profile (~/.aws/credentials).

DYNAMODB_TABLE_NAME=summarizinator-dev
AWS_REGION=us-east-1

# GitHub OAuth app credentials (data source connections, not identity auth).
#   aws ssm get-parameter --name /summarizinator/dev/github-client-id --query Parameter.Value --output text
#   aws ssm get-parameter --name /summarizinator/dev/github-client-secret --with-decryption --query Parameter.Value --output text
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Bedrock model (leave as-is unless you want to override)
BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-5-20250929-v1:0
